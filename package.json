{
  "name": "dnkbiz-course-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:3002": "next dev --port 3002",
    "dev:local": "next dev -H 127.0.0.1 -p 3100",
    "build": "next build",
    "start": "next start",
    "start:3002": "next start --port 3002",
    "start:local": "next start -H 127.0.0.1 -p 3100",
    "lint": "eslint .",
    "visual:build": "tsc -p ai/agent/visual_composer/tsconfig.json",
    "visual:compose": "npm run visual:build --silent && node ai/agent/visual_composer/dist/index.js",
    "visual:build-job": "npm run visual:build --silent && node ai/agent/visual_composer/dist/index.js --build-job",
    "visual:revise": "npm run visual:build --silent && node ai/agent/visual_composer/dist/index.js --revise",
    "visual:assets:index": "npm run visual:build --silent && node ai/agent/visual_composer/dist/index.js --index-assets",
    "visual:validate": "npm run visual:build --silent && node ai/agent/visual_composer/dist/index.js --validate",
    "visual:project-smoke": "npm run visual:build --silent && node ai/agent/visual_composer/dist/index.js --project-smoke",
    "visual:quality-check": "npm run visual:build --silent && node ai/agent/visual_composer/dist/index.js --quality-check",
    "visual:contact-sheet": "npm run visual:build --silent && node ai/agent/visual_composer/dist/index.js --contact-sheet",
    "visual:quality-sheet": "npm run visual:build --silent && node ai/agent/visual_composer/dist/index.js --quality-sheet",
    "visual:ai-smoke": "npm run visual:build --silent && node ai/agent/visual_composer/dist/index.js --ai-smoke",
    "visual:style-pack-smoke": "npm run visual:build --silent && node ai/agent/visual_composer/dist/index.js --style-pack-smoke",
    "visual:asset-selection-smoke": "npm run visual:build --silent && node ai/agent/visual_composer/dist/index.js --asset-selection-smoke",
    "visual:layered-smoke": "npm run visual:build --silent && node ai/agent/visual_composer/dist/index.js --layered-smoke",
    "visual:title-layer-smoke": "npm run visual:build --silent && node ai/agent/visual_composer/dist/index.js --title-layer-smoke",
    "visual:reference-flow-smoke": "npm run visual:build --silent && node ai/agent/visual_composer/dist/index.js --reference-flow-smoke",
    "visual:placement-smoke": "npm run visual:build --silent && node ai/agent/visual_composer/dist/index.js --placement-smoke",
    "visual:title-preprocess-smoke": "npm run visual:build --silent && node ai/agent/visual_composer/dist/index.js --title-preprocess-smoke",
    "visual:reference-provider-check": "npm run visual:build --silent && node ai/agent/visual_composer/dist/index.js --reference-provider-check",
    "visual:layer-pack-smoke": "npm run visual:build --silent && node ai/agent/visual_composer/dist/index.js --layer-pack-smoke",
    "visual:ai-usage": "npm run visual:build --silent && node ai/agent/visual_composer/dist/index.js --ai-usage",
    "visual:ai-usage:reset": "npm run visual:build --silent && node ai/agent/visual_composer/dist/index.js --ai-usage-reset",
    "visual:api:test": "node ai/agent/visual_composer/scripts/test-api-compose.mjs",
    "visual:produce:test": "node ai/agent/visual_composer/scripts/test-api-produce.mjs",
    "visual:produce:local": "npm run visual:build --silent && node ai/agent/visual_composer/scripts/produce-local.mjs",
    "telegram:visual:build": "tsc -p ai/agent/telegram_visual_bot/tsconfig.json",
    "telegram:visual:smoke": "npm run telegram:visual:build --silent && node ai/agent/telegram_visual_bot/scripts/smoke.mjs",
    "telegram:visual:set-webhook": "npm run telegram:visual:build --silent && node ai/agent/telegram_visual_bot/scripts/set-webhook.mjs",
    "telegram:visual:delete-webhook": "npm run telegram:visual:build --silent && node ai/agent/telegram_visual_bot/scripts/delete-webhook.mjs",
    "telegram:visual:get-webhook": "npm run telegram:visual:build --silent && node ai/agent/telegram_visual_bot/scripts/get-webhook-info.mjs",
    "telegram:visual:drop-pending": "npm run telegram:visual:build --silent && node ai/agent/telegram_visual_bot/scripts/drop-pending.mjs",
    "telegram:visual:debug-smoke": "npm run telegram:visual:build --silent && node ai/agent/telegram_visual_bot/scripts/debug-smoke.mjs",
    "db:generate": "prisma generate",
    "db:seed": "node --env-file=.env prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "next": "16.2.3",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "typescript": "^5"
  }
}

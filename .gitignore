# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.next-*.log
.next-*.err
.smoke-*.html
.smoke-*.out
.smoke-*.err
.smoke-*.json
.smoke-*.cookies
*.tmp

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.visual-bot.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# Local Codex / browser smoke artifacts
.codex-*/
.codex-*
.codex_backups/
.chrome-*/
.codex*.log
.codex-start-local.log
.codex-dev-*.log
prisma/dev.db

# Local n8n workflow backups may contain exported credentials or tokens
/ai/agent/ai_bot_designer/backups/

# Visual composer generated build/cache artifacts
/ai/agent/visual_composer/dist/
/ai/agent/telegram_visual_bot/dist/
/ai/agent/visual_composer/.cache/
/ai/agent/visual_composer/examples/outputs/*.png
/ai/agent/visual_composer/examples/outputs/project-smoke/*.png
/ai/agent/visual_composer/examples/outputs/jobs/*.json
/ai/agent/visual_composer/examples/outputs/jobs/**/*.json
/ai/agent/visual_assets/manifest.local.json
/ai/agent/visual_assets/manual_project_packs/**/*
!/ai/agent/visual_assets/manual_project_packs/README.md
!/ai/agent/visual_assets/manual_project_packs/**/
!/ai/agent/visual_assets/manual_project_packs/**/README.md

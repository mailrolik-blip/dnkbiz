{
  "font_family": "Arial Black, Arial, Helvetica, sans-serif",
  "font_path_env": "VISUAL_PAY_TITLE_FONT_PATH",
  "font_size_range": [62, 184],
  "line_height": 0.94,
  "tracking": 0,
  "fill_gradient": ["#fff58a", "#ffc83d", "#ff891f"],
  "face_gradient": ["#fff58a", "#ffc83d", "#ff891f"],
  "stroke_width": 15,
  "stroke_color": "#1b1243",
  "primary_stroke": { "color": "#1b1243", "width": 15 },
  "secondary_stroke": { "color": "#3f1b78", "width": 24 },
  "highlight": { "color": "#ffffff", "opacity": 0.22 },
  "face_highlight": { "color": "#ffffff", "opacity": 0.22 },
  "extrusion": { "steps": 15, "x_step": 5, "y_step": 6, "colors": ["#120c34", "#241257", "#432185"] },
  "extrusion_steps": 15,
  "extrusion_x_step": 5,
  "extrusion_y_step": 6,
  "extrusion_color_start": "#120c34",
  "extrusion_color_end": "#432185",
  "shadow": { "offset": [24, 30], "blur": 10, "opacity": 0.42 },
  "shadow_offset": [24, 30],
  "shadow_blur": 10,
  "shadow_opacity": 0.42,
  "padding": 54
}

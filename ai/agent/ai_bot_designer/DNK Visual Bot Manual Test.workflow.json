            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Build Photo URL": {
      "main": [
        [
          {
            "node": "Telegram API Send Photo",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
